# Simple HTTP server example
import std.net
import std.io

fn handle_request(request) {
    io.println("Received request: " + request.path)
    return {
        status: 200,
        body: "Hello from m5rcode server!"
    }
}

fn main() {
    server = net.HttpServer.new("127.0.0.1:8080")
    io.println("Server listening on http://127.0.0.1:8080")
    
    server.handle(handle_request)
    server.run()
}

main()

# ============================================================================
# HELPER FUNCTIONS
# ============================================================================

fn parse_user_id(mention) {
    # Extract user ID from mention like <@123456>
    # For now, return the mention as-is (bridge will handle)
    return mention
}

fn parse_duration(duration_str) {
    # Parse duration like "5m", "1h", "1d" to seconds
    # Simple implementation
    if duration_str == "5m" { return 300 }
    if duration_str == "1h" { return 3600 }
    if duration_str == "1d" { return 86400 }
    return 600
}

# ============================================================================
# MODERATION COMMANDS
# ============================================================================

fn cmd_kick() {
    let args = DISCORD_ARGS
    if args == "" {
        io.println("Usage: !kick <@user> [reason]")
        return
    }
    
    # Parse: @user reason
    # Simplified - assumes first word is user ID, rest is reason
    io.println("🚫 Kick command executed")
    io.println("Use: !kick <@user> [reason]")
}

fn cmd_ban() {
    let args = DISCORD_ARGS
    if args == "" {
        io.println("Usage: !ban <@user> [reason]")
        return

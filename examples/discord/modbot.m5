# ============================================================================
# COMMAND ROUTER
# ============================================================================

fn main() {
    # DISCORD_COMMAND is injected by the bridge at the top of the file
    # If not set (local testing), it defaults to "help"
    let cmd = DISCORD_COMMAND
    
    # Route to appropriate handler
    if cmd == "help" { 
        cmd_help() 
    } else if cmd == "info" { 
        cmd_info() 
    } else if cmd == "ping" { 
        cmd_ping() 
    } else if cmd == "kick" { 
        cmd_kick() 
    } else if cmd == "ban" { 
        cmd_ban() 
    } else if cmd == "unban" { 
        cmd_unban() 
    } else if cmd == "mute" { 
        cmd_mute() 
    } else if cmd == "unmute" { 
        cmd_unmute() 
    } else if cmd == "warn" { 
        cmd_warn() 
    } else if cmd == "warnings" { 
        cmd_warnings() 
    } else if cmd == "clearwarns" { 
        cmd_clearwarns() 
    } else if cmd == "purge" { 
        cmd_purge() 
    } else if cmd == "slowmode" { 
        cmd_slowmode() 
    } else if cmd == "lock" { 
        cmd_lock() 
    } else if cmd == "unlock" { 
        cmd_unlock() 
    } else if cmd == "userinfo" { 
        cmd_userinfo() 
    } else if cmd == "serverinfo" { 
        cmd_serverinfo() 
    } else if cmd == "modlogs" { 
        cmd_modlogs() 
    } else if cmd == "addrole" { 
        cmd_addrole() 
    } else if cmd == "removerole" { 
        cmd_removerole() 
    } else if cmd == "automod" { 
        cmd_automod() 
    }
}

# Default for local testing (will be overridden by bridge)
let DISCORD_COMMAND = "help"
let DISCORD_ARGS = ""
let DISCORD_AUTHOR = "TestUser"

main()
